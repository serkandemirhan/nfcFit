## New Supabase project values for the web app.
VITE_SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_NEW_SUPABASE_ANON_KEY

## Vercel serverless API values. Set these in Vercel Environment Variables.
SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_NEW_SUPABASE_SERVICE_ROLE_KEY
API_ALLOWED_ORIGINS=https://YOUR-NEW-VERCEL-APP.vercel.app

## Local development: use the new Supabase schema directly from Vite.
VITE_USE_SUPABASE_IN_DEV=true
